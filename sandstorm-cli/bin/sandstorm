#!/bin/bash
#
# Sandstorm — Claude Code orchestration harness
#
# Launches Claude Code with the Sandstorm outer CLAUDE.md,
# or delegates to stack management commands.
#
# Usage:
#   sandstorm                          # Start outer Claude (interactive)
#   sandstorm up 1                     # Start a stack
#   sandstorm task 1 "fix the bug"     # Dispatch task to inner Claude
#   sandstorm push 1 "commit message"  # Push changes from stack
#
set -e

SANDSTORM_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Init command — delegate to lib/init.sh (before stack.sh, which requires config)
if [[ "${1:-}" == "init" ]]; then
  source "$SANDSTORM_DIR/lib/init.sh"
  exit $?
fi

# Sync skills — install/update Claude skills in an already-initialized project
if [[ "${1:-}" == "sync-skills" ]]; then
  SKILLS_SRC="$SANDSTORM_DIR/skills"
  SKILLS_DEST="$(pwd)/.claude/skills"
  if [ ! -d "$SKILLS_SRC" ]; then
    echo "No skills to install." >&2
    exit 1
  fi
  mkdir -p "$SKILLS_DEST"
  cp "$SKILLS_SRC"/sandstorm-*.md "$SKILLS_DEST/"
  echo "Synced Claude skills to .claude/skills/"
  exit 0
fi

# Stack management commands — delegate to lib/stack.sh
STACK_COMMANDS="up|down|task|task-status|task-output|diff|push|publish|status|exec|claude|register|logs"

if [[ "${1:-}" =~ ^($STACK_COMMANDS)$ ]]; then
  source "$SANDSTORM_DIR/lib/stack.sh"
  exit $?
fi

# Default: launch Claude Code with the Sandstorm outer CLAUDE.md and settings
exec claude --system-prompt-file "$SANDSTORM_DIR/SANDSTORM_OUTER.md" "$@"
