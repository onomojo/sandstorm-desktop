{
  "name": "sandstorm-desktop",
  "version": "0.1.0",
  "type": "module",
  "description": "Desktop control plane for Sandstorm agent orchestration",
  "author": {
    "name": "Sandstorm",
    "email": "dev@sandstorm.dev"
  },
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "package:all": "electron-builder -mwl",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration:docker": "vitest run --config vitest.integration.config.ts",
    "test:integration": "xvfb-run --auto-servernum playwright test --config playwright.integration.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "release": "bash scripts/build.sh"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.8.0",
    "detect-port": "^2.0.0",
    "dockerode": "^4.0.4",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^4.0.5",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^3.3.34",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.17.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
